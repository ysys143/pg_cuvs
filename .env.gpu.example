# Copy to .env.gpu (gitignored). Source of truth for GCP VM coordinates.
# Used by Makefile's vm-start, sync, gpu-* targets.

GCP_VM=USER@EXTERNAL_IP
GCP_INSTANCE=pg-cuvs-dev
GCP_ZONE=us-central1-a
GCP_PROJECT=your-gcp-project

# Conda env on the VM where libcuvs is installed (per README build step)
CONDA_ENV=cuvs_dev

# CUDA architecture for nvcc (L4 = sm_89, A100 = sm_80, H100 = sm_90)
CUDA_ARCH=sm_89

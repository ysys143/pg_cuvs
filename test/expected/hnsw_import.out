-- hnsw_import.sql — pg_cuvs_build_hnsw: GPU HNSW creation without CPU build.
--
-- Verifies that pg_cuvs_build_hnsw():
--   1. Function is registered.
--   2. Creates pgvector HNSW WITHOUT pgvector CPU build (INDEX_CREATE_SKIP_BUILD).
--   3. Resulting HNSW returns correct top-2 for deterministic test vectors.
--
-- REQUIRES: pg_cuvs_server running with GPU, cuvs.index_dir writable.
-- NOTE: 20 vectors used so n_vecs >= 16 (CAGRA graph threshold).
\set ON_ERROR_STOP on
CREATE EXTENSION IF NOT EXISTS vector;
NOTICE:  extension "vector" already exists, skipping
CREATE EXTENSION IF NOT EXISTS pg_cuvs;
-- Function registered?
SELECT proname FROM pg_proc WHERE proname = 'pg_cuvs_build_hnsw';
      proname       
--------------------
 pg_cuvs_build_hnsw
(1 row)

-- Setup: 20-vector 4-dim table. Query [1,0.5,0,0] has unambiguous top-2.
SET cuvs.index_dir = '/tmp/cuvs_indexes';
CREATE TABLE hnsw_import_test (id bigint, embedding vector(4));
INSERT INTO hnsw_import_test VALUES
    (1,  '[1,0,0,0]'),
    (2,  '[0,1,0,0]'),
    (3,  '[0,0,1,0]'),
    (4,  '[0,0,0,1]'),
    (5,  '[0.1,0,0,0]'),
    (6,  '[0,0.1,0,0]'),
    (7,  '[0,0,0.1,0]'),
    (8,  '[0,0,0,0.1]'),
    (9,  '[0.5,0.5,0,0]'),
    (10, '[0,0.5,0.5,0]'),
    (11, '[0,0,0.5,0.5]'),
    (12, '[0.5,0,0.5,0]'),
    (13, '[0.5,0,0,0.5]'),
    (14, '[0,0.5,0,0.5]'),
    (15, '[0.3,0.3,0.3,0]'),
    (16, '[0.3,0.3,0,0.3]'),
    (17, '[0.3,0,0.3,0.3]'),
    (18, '[0,0.3,0.3,0.3]'),
    (19, '[0.25,0.25,0.25,0.25]'),
    (20, '[0.9,0.1,0,0]');
-- Build CAGRA index (no cpu_hnsw_fallback needed for nsw mode).
CREATE INDEX cagra_import_idx ON hnsw_import_test
    USING cagra (embedding vector_l2_ops);
-- pg_cuvs_build_hnsw: creates HNSW directly, no pgvector CPU build.
-- Suppress NOTICE (contains variable OIDs).
SET client_min_messages = 'warning';
SELECT pg_cuvs_build_hnsw('cagra_import_idx'::regclass) IS NOT NULL AS hnsw_created;
 hnsw_created 
--------------
 t
(1 row)

SET client_min_messages = 'notice';
-- Disable GPU path so we prove the pgvector HNSW index is used.
SET enable_cuvs = off;
SET enable_seqscan = off;
-- Query via pgvector HNSW: top-2 is id=20 (dist=0.41) then id=1 (dist=0.50).
SELECT id FROM hnsw_import_test
ORDER BY embedding <-> '[1,0.5,0,0]'::vector
LIMIT 2;
 id 
----
 20
  1
(2 rows)

SET enable_cuvs = on;
RESET enable_seqscan;
-- Cleanup.
DROP TABLE hnsw_import_test;
DROP EXTENSION pg_cuvs;

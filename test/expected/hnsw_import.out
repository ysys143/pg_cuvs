-- hnsw_import.sql — Phase 3I-2: cuVS HNSW -> pgvector adapter.
--
-- Verifies that pg_cuvs_import_hnsw():
--   1. Function is registered.
--   2. Reads .hnsw sidecar + .tids and writes pgvector HNSW pages.
--   3. Resulting HNSW index returns correct top-2 for deterministic test vectors.
--
-- REQUIRES: pg_cuvs_server running with GPU, cuvs.index_dir writable.
-- NOTE: 20 vectors used so n_vecs >= 16 (HNSW serialization threshold).
\set ON_ERROR_STOP on
CREATE EXTENSION IF NOT EXISTS vector;
NOTICE:  extension "vector" already exists, skipping
CREATE EXTENSION IF NOT EXISTS pg_cuvs;
-- Function registered?
SELECT proname FROM pg_proc WHERE proname = 'pg_cuvs_import_hnsw';
       proname       
---------------------
 pg_cuvs_import_hnsw
(1 row)

-- Setup: 20-vector 4-dim table. Query [1,0.5,0,0] has unambiguous top-2.
SET cuvs.index_dir = '/tmp/cuvs_indexes';
CREATE TABLE hnsw_import_test (id bigint, embedding vector(4));
INSERT INTO hnsw_import_test VALUES
    (1,  '[1,0,0,0]'),
    (2,  '[0,1,0,0]'),
    (3,  '[0,0,1,0]'),
    (4,  '[0,0,0,1]'),
    (5,  '[0.1,0,0,0]'),
    (6,  '[0,0.1,0,0]'),
    (7,  '[0,0,0.1,0]'),
    (8,  '[0,0,0,0.1]'),
    (9,  '[0.5,0.5,0,0]'),
    (10, '[0,0.5,0.5,0]'),
    (11, '[0,0,0.5,0.5]'),
    (12, '[0.5,0,0.5,0]'),
    (13, '[0.5,0,0,0.5]'),
    (14, '[0,0.5,0,0.5]'),
    (15, '[0.3,0.3,0.3,0]'),
    (16, '[0.3,0.3,0,0.3]'),
    (17, '[0.3,0,0.3,0.3]'),
    (18, '[0,0.3,0.3,0.3]'),
    (19, '[0.25,0.25,0.25,0.25]'),
    (20, '[0.9,0.1,0,0]');
-- Build CAGRA index. cpu_hnsw_fallback=on tells the daemon to serialize the
-- .hnsw sidecar — required for pg_cuvs_import_hnsw to read it.
SET cuvs.cpu_hnsw_fallback = on;
CREATE INDEX cagra_import_idx ON hnsw_import_test
    USING cagra (embedding vector_l2_ops);
SET cuvs.cpu_hnsw_fallback = off;
-- Create empty pgvector HNSW target (same dimensions, same M=16 default).
CREATE INDEX pgvec_hnsw_idx ON hnsw_import_test
    USING hnsw (embedding vector_l2_ops);
-- Import GPU-built graph into pgvector HNSW.
-- Suppress the NOTICE (contains variable OIDs/paths, unsuitable for exact match).
SET client_min_messages = 'warning';
SELECT pg_cuvs_import_hnsw('cagra_import_idx'::regclass,
                             'pgvec_hnsw_idx'::regclass);
WARNING:  you don't own a lock of type ExclusiveLock
 pg_cuvs_import_hnsw 
---------------------
 
(1 row)

SET client_min_messages = 'notice';
-- Disable GPU path so we prove the pgvector HNSW index is used.
SET enable_cuvs = off;
-- Query via pgvector HNSW: top-2 is id=20 (dist=0.41) then id=1 (dist=0.50).
SELECT id FROM hnsw_import_test
ORDER BY embedding <-> '[1,0.5,0,0]'::vector
LIMIT 2;
 id 
----
 20
  1
(2 rows)

SET enable_cuvs = on;
-- Cleanup.
DROP TABLE hnsw_import_test;
DROP EXTENSION pg_cuvs;

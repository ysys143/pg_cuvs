-- partition_prune.sql — online-scale pattern: LIST partition by tenant + per-partition
--   CAGRA index. Verifies PG partition pruning routes `WHERE tenant_id = X` to a SINGLE
--   child cagra index scan (no Append over other partitions) and execution stays confined
--   to that partition; contrast: an unfiltered query fans out (Merge Append) over all.
-- This is the "online large-scale = partition pruning + LRU" model (STRATEGY_NOTES §G,
--   ADR-061). LRU evict/reload capacity needs daemon-budget control and is covered by a
--   manual spike, not here. REQUIRES: pg_cuvs_server running with GPU; cuvs.index_dir writable.
\set ON_ERROR_STOP off
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS vector;
CREATE EXTENSION IF NOT EXISTS pg_cuvs;
SET cuvs.index_dir = '/tmp/cuvs_indexes';
-- LIST partition by a query-aligned key (tenant_id). 4 tenants x 2000 distinct rows.
CREATE TABLE pp (tenant_id int NOT NULL, id bigint NOT NULL, v vector(16))
  PARTITION BY LIST (tenant_id);
CREATE TABLE pp_t1 PARTITION OF pp FOR VALUES IN (1);
CREATE TABLE pp_t2 PARTITION OF pp FOR VALUES IN (2);
CREATE TABLE pp_t3 PARTITION OF pp FOR VALUES IN (3);
CREATE TABLE pp_t4 PARTITION OF pp FOR VALUES IN (4);
-- distinct per-row vectors (cross join + GROUP BY -> random() per (id,d))
INSERT INTO pp
SELECT t, t*100000 + g, array_agg(random() ORDER BY d)::real[]::vector(16)
FROM generate_series(1,4) t, generate_series(1,2000) g, generate_series(1,16) d
GROUP BY t, g;
CREATE INDEX pp_t1_cagra ON pp_t1 USING cagra (v vector_l2_ops);
CREATE INDEX pp_t2_cagra ON pp_t2 USING cagra (v vector_l2_ops);
CREATE INDEX pp_t3_cagra ON pp_t3 USING cagra (v vector_l2_ops);
CREATE INDEX pp_t4_cagra ON pp_t4 USING cagra (v vector_l2_ops);
SET enable_seqscan = off;
SET max_parallel_workers_per_gather = 0;  -- deterministic serial plans for EXPLAIN golden
SET cuvs.k = 32;
-- 1. PRUNING: WHERE tenant_id = 2 -> single child cagra Index Scan, NO Append.
EXPLAIN (COSTS OFF)
SELECT id FROM pp WHERE tenant_id = 2
ORDER BY v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)
LIMIT 10;
                                                    QUERY PLAN                                                    
------------------------------------------------------------------------------------------------------------------
 Limit
   ->  Index Scan using pp_t2_cagra on pp_t2 pp
         Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
         Filter: (tenant_id = 2)
(4 rows)

-- 2. confinement: pruned query returns 10 rows, all from tenant 2 (wrong_tenant = 0).
SELECT count(*) AS n, count(*) FILTER (WHERE tenant_id <> 2) AS wrong_tenant
FROM (
  SELECT tenant_id FROM pp WHERE tenant_id = 2
  ORDER BY v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)
  LIMIT 10
) s;
 n  | wrong_tenant 
----+--------------
 10 |            0
(1 row)

-- 3. partial pruning: IN (2,3) -> Append/Merge over only t2,t3 (not t1,t4).
EXPLAIN (COSTS OFF)
SELECT id FROM pp WHERE tenant_id IN (2,3)
ORDER BY v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)
LIMIT 10;
                                                       QUERY PLAN                                                       
------------------------------------------------------------------------------------------------------------------------
 Limit
   ->  Merge Append
         Sort Key: ((pp.v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)))
         ->  Index Scan using pp_t2_cagra on pp_t2 pp_1
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
               Filter: (tenant_id = ANY ('{2,3}'::integer[]))
         ->  Index Scan using pp_t3_cagra on pp_t3 pp_2
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
               Filter: (tenant_id = ANY ('{2,3}'::integer[]))
(9 rows)

-- 4. CONTRAST: no filter -> Merge Append over ALL partitions (fan-out).
EXPLAIN (COSTS OFF)
SELECT id FROM pp
ORDER BY v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)
LIMIT 10;
                                                       QUERY PLAN                                                       
------------------------------------------------------------------------------------------------------------------------
 Limit
   ->  Merge Append
         Sort Key: ((pp.v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16)))
         ->  Index Scan using pp_t1_cagra on pp_t1 pp_1
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
         ->  Index Scan using pp_t2_cagra on pp_t2 pp_2
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
         ->  Index Scan using pp_t3_cagra on pp_t3 pp_3
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
         ->  Index Scan using pp_t4_cagra on pp_t4 pp_4
               Order By: (v <-> '[0.9,0.1,0.5,0.3,0.7,0.2,0.8,0.4,0.6,0.15,0.85,0.35,0.65,0.25,0.75,0.45]'::vector(16))
(11 rows)

RESET enable_seqscan;
DROP TABLE pp CASCADE;
